{
  "name": "eslint-config-availity",
  "version": "13.0.0",
  "description": "Shareable ESLint config for Availity projects",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./base": "./base.js",
    "./base.js": "./base.js",
    "./browser": "./browser.js",
    "./browser.js": "./browser.js",
    "./workflow": "./workflow.js",
    "./workflow.js": "./workflow.js",
    "./compat": "./compat.js",
    "./compat.js": "./compat.js"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run",
    "release": "standard-version",
    "release:dry-run": "standard-version --dry-run",
    "eslint-check": "npx eslint-config-prettier eslint.config.js",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Availity/eslint-config-availity.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "availity"
  ],
  "files": [
    "index.js",
    "browser.js",
    "workflow.js",
    "base.js",
    "compat.js",
    "README.md"
  ],
  "author": "Robert McGuinness",
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Availity/eslint-config-availity/issues"
  },
  "homepage": "https://github.com/Availity/eslint-config-availity#readme",
  "dependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@vitest/eslint-plugin": "^1.6.19",
    "eslint": "^9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^65.0.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.1"
  },
  "peerDependencies": {
    "typescript": "^5.2.2"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/react": "^19.2.17",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "react": "^19.2.7",
    "standard-version": "^9.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        0,
        "always",
        100
      ],
      "body-max-line-length": [
        0,
        "always",
        500
      ],
      "footer-max-line-length": [
        0,
        "always",
        500
      ]
    }
  },
  "standard-version": {
    "releaseCommitMessageFormat": "chore(release): {{currentTag}} [skip ci]"
  },
  "packageManager": "yarn@4.12.0"
}
